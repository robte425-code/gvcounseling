{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]",
  "crons": [
    {
      "path": "/api/cron/pending-referral-reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/cutoff-reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/payment-due-reminders",
      "schedule": "0 15 * * *"
    }
  ]
}
