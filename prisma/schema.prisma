generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  THERAPIST
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  BILLED
}

enum PaymentStatus {
  PAID
  UNPAID
  DENIED
  APPEAL_IN_PROGRESS
}

enum Gender {
  M
  F
  U
}

enum ClientAssignmentStatus {
  UNASSIGNED
  PENDING_THERAPIST
  ACTIVE
  REJECTED_BY_ADMIN
  CLOSED
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  role               Role
  firstName          String
  lastName           String
  mustChangePassword Boolean   @default(true)
  active             Boolean   @default(true)
  lniProviderId      String?
  npi                String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  clients            Client[]
  invoices           Invoice[]
  billsGenerated     Bill[]    @relation("BillGeneratedBy")
  procedureCodeFees  ProcedureCodeFee[] @relation("ProcedureCodeFeeCreatedBy")
  therapistProcedureCodeFees TherapistProcedureCodeFee[] @relation("TherapistProcedureCodeFees")
  therapistProcedureCodeFeesCreated TherapistProcedureCodeFee[] @relation("TherapistProcedureCodeFeeCreatedBy")
  googleDriveConnection GoogleDriveConnection?
}

model PayPeriod {
  id          String   @id @default(cuid())
  cutoffDate  DateTime
  paymentDate DateTime?
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bills       Bill[]
  invoices    Invoice[]
}

model Client {
  id             String    @id @default(cuid())
  lniClaimNumber String    @unique
  firstName      String
  lastName       String
  middleInitial  String?
  attendingNpi   String?
  diagnoses      String[]
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String    @default("WA")
  zip            String?
  residenceAddressLine1 String?
  residenceCity         String?
  residenceState        String?
  residenceZip          String?
  workerPhone           String?
  employerName          String?
  attendingDoctorName   String?
  attendingDoctorAddress String?
  attendingDoctorPhone  String?
  claimManagerName      String?
  claimManagerPhone     String?
  claimManagerFax       String?
  legalRepresentativeName     String?
  legalRepresentativeAddress  String?
  legalRepresentativePhone    String?
  dateOfBirth    DateTime?
  gender         Gender?
  dateOfInjury   DateTime?
  vrcName        String?
  vrcEmail       String?
  vrcPhone       String?
  referralClientEmail String?
  pgapCoach      String?
  languages      String?
  priorServices  String?
  clientHistory  String?
  assignmentStatus ClientAssignmentStatus @default(ACTIVE)
  driveFolderId  String?
  rejectionReason String?
  rejectedAt     DateTime?
  closedAt       DateTime?
  therapistId    String?
  therapist      User?     @relation(fields: [therapistId], references: [id])
  invoices       Invoice[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([therapistId])
}

model Invoice {
  id               String              @id @default(cuid())
  invoiceNumber    Int
  status           InvoiceStatus       @default(DRAFT)
  therapistId      String
  therapist        User                @relation(fields: [therapistId], references: [id])
  clientId         String
  client           Client              @relation(fields: [clientId], references: [id])
  billId           String?
  bill             Bill?               @relation(fields: [billId], references: [id])
  payPeriodId      String?
  payPeriod        PayPeriod?          @relation(fields: [payPeriodId], references: [id])
  clmControlNumber String?
  totalAmount      Decimal             @db.Decimal(10, 2)
  submittedAt      DateTime?
  billedAt         DateTime?
  paymentStatus    PaymentStatus?
  lniPaidAt        DateTime?
  lineItems        InvoiceLineItem[]
  attachments      InvoiceAttachment[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([therapistId, invoiceNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([clientId])
  @@index([billId])
  @@index([payPeriodId])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceDate   DateTime
  procedureCode String
  amount        Decimal  @db.Decimal(10, 2)
  units         Int      @default(1)
  sortOrder     Int      @default(0)

  @@index([invoiceId])
}

model InvoiceAttachment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filename    String
  blobUrl     String
  contentType String
  size        Int
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model Bill {
  id            String    @id @default(cuid())
  payPeriodId   String
  payPeriod     PayPeriod @relation(fields: [payPeriodId], references: [id])
  filename      String
  isaControl    String
  gsControl     String
  invoiceCount  Int
  totalAmount   Decimal   @db.Decimal(12, 2)
  ediContent    String    @db.Text
  generatedAt   DateTime  @default(now())
  generatedById String
  generatedBy   User      @relation("BillGeneratedBy", fields: [generatedById], references: [id])
  invoices      Invoice[]

  @@index([payPeriodId])
}

model ProcedureCodeFee {
  id            String    @id @default(cuid())
  procedureCode String
  amount        Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())
  createdById   String?
  createdBy     User?     @relation("ProcedureCodeFeeCreatedBy", fields: [createdById], references: [id])

  @@unique([procedureCode, effectiveFrom])
  @@index([procedureCode, effectiveFrom])
}

model TherapistProcedureCodeFee {
  id            String    @id @default(cuid())
  therapistId   String
  therapist     User      @relation("TherapistProcedureCodeFees", fields: [therapistId], references: [id], onDelete: Cascade)
  procedureCode String
  amount        Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())
  createdById   String?
  createdBy     User?     @relation("TherapistProcedureCodeFeeCreatedBy", fields: [createdById], references: [id])

  @@unique([therapistId, procedureCode, effectiveFrom])
  @@index([therapistId, procedureCode, effectiveFrom])
}

model GoogleDriveConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail  String?
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
