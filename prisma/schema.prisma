generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  THERAPIST
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  BILLED
}

enum PaymentStatus {
  PAID
  DENIED
  IN_PROCESS
  UNPAID
  APPEAL_IN_PROGRESS
}

enum RemittanceBillSection {
  PAID
  DENIED
  IN_PROCESS
}

enum TherapistPayRunStatus {
  DRAFT
  FINALIZED
}

enum RemittanceAdviceStatus {
  PREVIEW
  APPLIED
}

enum RemittanceSourceFormat {
  PDF_RA
  ERA_835
}

enum Gender {
  M
  F
  U
}

enum ClientAssignmentStatus {
  UNASSIGNED
  PENDING_THERAPIST
  ACTIVE
  REJECTED_BY_ADMIN
  CLOSED
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  role               Role
  firstName          String
  lastName           String
  mustChangePassword Boolean   @default(true)
  active             Boolean   @default(true)
  lniProviderId      String?
  npi                String?
  stripeConnectAccountId String?  @unique
  stripeConnectReady Boolean  @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  clients            Client[]
  invoices           Invoice[]
  procedureCodeFees  ProcedureCodeFee[] @relation("ProcedureCodeFeeCreatedBy")
  therapistProcedureCodeFees TherapistProcedureCodeFee[] @relation("TherapistProcedureCodeFees")
  therapistProcedureCodeFeesCreated TherapistProcedureCodeFee[] @relation("TherapistProcedureCodeFeeCreatedBy")
  googleDriveConnection GoogleDriveConnection?
  clientNotes         ClientNote[]
  invoiceNotes        InvoiceNote[]
  importedRemittances RemittanceAdvice[] @relation("RemittanceImportedBy")
  therapistPayPayouts TherapistPayRunPayout[]
  edi837Submissions   Edi837Submission[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PayPeriod {
  id          String   @id @default(cuid())
  cutoffDate  DateTime
  paymentDate DateTime?
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoices    Invoice[]
  edi837Submissions Edi837Submission[]
}

model Edi837Submission {
  id                String   @id @default(cuid())
  payPeriodId       String
  payPeriod         PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  generatedById     String
  generatedBy       User     @relation(fields: [generatedById], references: [id])
  isaUsageIndicator String
  filename          String
  isaControl        String
  gsControl         String
  claimCount        Int
  totalAmount       Decimal  @db.Decimal(12, 2)
  contentSha256     String
  invoiceSnapshot   Json
  generatedAt       DateTime @default(now())

  @@index([payPeriodId, generatedAt])
  @@index([generatedAt])
}

model Client {
  id             String    @id @default(cuid())
  lniClaimNumber String    @unique
  firstName      String
  lastName       String
  middleInitial  String?
  attendingNpi   String?
  diagnoses      String[]
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String    @default("WA")
  zip            String?
  residenceAddressLine1 String?
  residenceCity         String?
  residenceState        String?
  residenceZip          String?
  workerPhone           String?
  employerName          String?
  selfInsured           Boolean   @default(false)
  employerFax           String?
  attendingDoctorName   String?
  attendingDoctorAddress String?
  attendingDoctorPhone  String?
  claimManagerName      String?
  claimManagerPhone     String?
  claimManagerFax       String?
  legalRepresentativeName     String?
  legalRepresentativeAddress  String?
  legalRepresentativePhone    String?
  dateOfBirth    DateTime?
  gender         Gender?
  dateOfInjury   DateTime?
  vrcName        String?
  vrcEmail       String?
  vrcPhone       String?
  referralClientEmail String?
  pgapCoach      String?
  languages      String?
  priorServices  String?
  clientHistory  String?
  assignmentStatus ClientAssignmentStatus @default(ACTIVE)
  driveFolderId  String?
  rejectionReason String?
  rejectedAt     DateTime?
  closedAt       DateTime?
  therapistId    String?
  therapist      User?     @relation(fields: [therapistId], references: [id])
  invoices       Invoice[]
  notes          ClientNote[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([therapistId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, createdAt])
}

model Invoice {
  id               String              @id @default(cuid())
  invoiceNumber    Int
  status           InvoiceStatus       @default(DRAFT)
  therapistId      String
  therapist        User                @relation(fields: [therapistId], references: [id])
  clientId         String
  client           Client              @relation(fields: [clientId], references: [id])
  payPeriodId      String?
  payPeriod        PayPeriod?          @relation(fields: [payPeriodId], references: [id])
  clmControlNumber String?
  totalAmount      Decimal             @db.Decimal(10, 2)
  submittedAt      DateTime?
  billedAt         DateTime?
  paymentStatus    PaymentStatus?
  lniPaidAt        DateTime?
  lniEobCodes      String[]            @default([])
  lniEobCodeDescriptions Json            @default("{}")
  lineItems        InvoiceLineItem[]
  attachments      InvoiceAttachment[]
  notes            InvoiceNote[]
  remittanceLines  RemittanceAdviceLine[]
  payRunLines      TherapistPayRunLine[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([therapistId, invoiceNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([clientId])
  @@index([payPeriodId])
}

model InvoiceNote {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId, createdAt])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceDate   DateTime
  procedureCode String
  amount        Decimal  @db.Decimal(10, 2)
  units         Int      @default(1)
  sortOrder     Int      @default(0)

  @@index([invoiceId])
}

model InvoiceAttachment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filename    String
  blobUrl     String
  contentType String
  size        Int
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model ProcedureCodeFee {
  id            String    @id @default(cuid())
  procedureCode String
  amount        Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())
  createdById   String?
  createdBy     User?     @relation("ProcedureCodeFeeCreatedBy", fields: [createdById], references: [id])

  @@unique([procedureCode, effectiveFrom])
  @@index([procedureCode, effectiveFrom])
}

model TherapistProcedureCodeFee {
  id            String    @id @default(cuid())
  therapistId   String
  therapist     User      @relation("TherapistProcedureCodeFees", fields: [therapistId], references: [id], onDelete: Cascade)
  procedureCode String
  amount        Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())
  createdById   String?
  createdBy     User?     @relation("TherapistProcedureCodeFeeCreatedBy", fields: [createdById], references: [id])

  @@unique([therapistId, procedureCode, effectiveFrom])
  @@index([therapistId, procedureCode, effectiveFrom])
}

model GoogleDriveConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail  String?
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RemittanceAdvice {
  id               String   @id @default(cuid())
  remittanceNumber String
  warrantRegister  String
  invoiceDate      DateTime
  reportDate       DateTime?
  payeeNumber      String
  payeeName        String
  totalPaid        Decimal  @db.Decimal(10, 2)
  eobCodeDescriptions Json  @default("{}")
  status           RemittanceAdviceStatus @default(PREVIEW)
  sourceFormat     RemittanceSourceFormat @default(PDF_RA)
  appliedAt        DateTime?
  sourceFilename   String?
  importedAt       DateTime @default(now())
  importedById     String
  importedBy       User     @relation("RemittanceImportedBy", fields: [importedById], references: [id])
  lines            RemittanceAdviceLine[]
  payRun           TherapistPayRun?

  @@unique([remittanceNumber, warrantRegister, sourceFormat])
  @@index([invoiceDate])
}

model RemittanceAdviceLine {
  id                 String                @id @default(cuid())
  remittanceAdviceId String
  remittanceAdvice   RemittanceAdvice      @relation(fields: [remittanceAdviceId], references: [id], onDelete: Cascade)
  section            RemittanceBillSection
  claimNumber        String
  icn                String
  patientName        String?
  serviceProviderId  String
  serviceProviderNpi String?
  serviceProviderName String?
  billTotalPayable   Decimal               @db.Decimal(10, 2)
  eobCodes           String[]
  eobCodeDescriptions Json               @default("{}")
  serviceLines       Json
  matchedInvoiceId   String?
  matchedInvoice     Invoice?              @relation(fields: [matchedInvoiceId], references: [id])
  matchNote          String?
  supersededAt       DateTime?
  supersedeNote      String?

  @@index([remittanceAdviceId])
  @@index([claimNumber])
  @@index([matchedInvoiceId])
}

model TherapistPayRun {
  id                 String                @id @default(cuid())
  remittanceAdviceId String                @unique
  remittanceAdvice   RemittanceAdvice      @relation(fields: [remittanceAdviceId], references: [id], onDelete: Cascade)
  status             TherapistPayRunStatus @default(DRAFT)
  finalizedAt        DateTime?
  stripePaidAt       DateTime?
  payouts            TherapistPayRunPayout[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model TherapistPayRunPayout {
  id                   String              @id @default(cuid())
  payRunId             String
  payRun               TherapistPayRun     @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  therapistId          String
  therapist            User                @relation(fields: [therapistId], references: [id])
  therapistAmount      Decimal             @db.Decimal(10, 2)
  lniPaidAmount        Decimal             @db.Decimal(10, 2)
  invoiceCount         Int
  stripeTransferId     String?             @unique
  stripeTransferStatus String?
  stripePaidAt         DateTime?
  lines                TherapistPayRunLine[]

  @@unique([payRunId, therapistId])
}

model TherapistPayRunLine {
  id              String              @id @default(cuid())
  payoutId        String
  payout          TherapistPayRunPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  invoiceId       String
  invoice         Invoice             @relation(fields: [invoiceId], references: [id])
  lniPaidAmount   Decimal             @db.Decimal(10, 2)
  therapistAmount Decimal             @db.Decimal(10, 2)

  @@unique([payoutId, invoiceId])
}

model PortalSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
  @@index([key])
}
